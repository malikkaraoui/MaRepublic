rules_version = '2';

// Règles Firestore : réactions citoyennes PSEUDONYMISÉES.
//
// Plus AUCUN email en clair dans la base : chaque retour porte une
// `empreinte` = sha256(email en minuscules), en hexadécimal minuscule.
// Les emails ne vivent que dans Firebase Auth (nécessaire au lien de
// connexion). Un vote lié à une opinion politique n'est donc jamais
// rattaché à un email lisible (minimisation RGPD, art. 9).
//
// - Canal site : connexion par lien exigée ; l'empreinte du retour DOIT
//   être celle de l'email du compte connecté (vérifiée par hachage côté
//   serveur, infalsifiable).
// - Canal api (agents IA déclarés) : signature `agent` exigée ET empreinte
//   ancrée : elle doit exister dans `empreintes_verifiees`, registre
//   alimenté uniquement par une connexion réelle sur le site.
// - 1 personne = 1 vote par fiche : identifiant de document imposé.
// - Lecture fermée partout : aucune énumération possible.

service cloud.firestore {
  match /databases/{database}/documents {

    // Empreinte de l'email du compte connecté, calculée par le serveur.
    function empreinteConnectee() {
      return hashing.sha256(request.auth.token.email.lower()).toHexString().lower();
    }

    match /reactions/{reactionId} {
      allow read: if false;
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly(
          ['ficheId', 'type', 'vote', 'texte', 'pseudo', 'empreinte', 'date', 'canal', 'agent']
        )
        && request.resource.data.empreinte is string
        && request.resource.data.empreinte.matches('[a-f0-9]{64}')
        && request.resource.data.canal in ['site', 'api']
        && (
          (request.resource.data.canal == 'site'
            && !('agent' in request.resource.data)
            && request.auth != null
            && request.resource.data.empreinte == empreinteConnectee())
          ||
          (request.resource.data.canal == 'api'
            && request.resource.data.agent is string
            && request.resource.data.agent.size() >= 2
            && request.resource.data.agent.size() <= 80
            && exists(/databases/$(database)/documents/empreintes_verifiees/$(request.resource.data.empreinte)))
        )
        && (request.resource.data.type != 'vote'
          || reactionId == 'v_' + request.resource.data.ficheId + '_' + request.resource.data.empreinte)
        && request.resource.data.ficheId is string
        && request.resource.data.ficheId.size() >= 3
        && request.resource.data.ficheId.size() <= 40
        && request.resource.data.pseudo is string
        && request.resource.data.pseudo.size() >= 2
        && request.resource.data.pseudo.size() <= 40
        && request.resource.data.type in ['vote', 'commentaire', 'alternative']
        && (
          (request.resource.data.type == 'vote'
            && request.resource.data.vote in ['pour', 'contre']
            && !('texte' in request.resource.data))
          ||
          (request.resource.data.type != 'vote'
            && !('vote' in request.resource.data)
            && request.resource.data.texte is string
            && request.resource.data.texte.size() >= 3
            && request.resource.data.texte.size() <= 500)
        )
        && request.resource.data.date == request.time;
    }

    // Registre des empreintes prouvées : alimenté par le site à la connexion.
    // On ne peut ancrer QUE l'empreinte de son propre email (hachage vérifié
    // par le serveur) : impossible d'ancrer des empreintes fabriquées.
    match /empreintes_verifiees/{empreinte} {
      allow read: if false;
      allow update, delete: if false;
      allow create: if
        request.auth != null
        && empreinte == empreinteConnectee()
        && request.resource.data.keys().hasOnly(['date'])
        && request.resource.data.date == request.time;
    }
  }
}
